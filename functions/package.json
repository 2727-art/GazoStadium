{
  "name": "gazostadium-functions",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "check": "node --check index.js && node --test test/*.test.js",
    "test:emulator": "node --test --test-concurrency=1 test/*emulator.test.js",
    "serve": "firebase emulators:start --only auth,functions,firestore,database --project demo-gazostadium"
  },
  "dependencies": {
    "firebase-admin": "14.2.0",
    "firebase-functions": "7.3.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "firebase": "12.16.0"
  }
}
