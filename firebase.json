{
  "database": {
    "rules": "database.rules.json"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run check"
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "database": {
      "port": 9000
    },
    "firestore": {
      "port": 8080
    },
    "functions": {
      "port": 5001
    }
  },
  "hosting": {
    "site": "gazostadium",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "database.rules.json",
      "README.md",
      ".git",
      ".git/**",
      ".firebase",
      ".firebase/**",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "firestore.rules",
      "firestore.indexes.json",
      "functions",
      "functions/**",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
