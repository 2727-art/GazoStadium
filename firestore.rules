rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isRoomMember() {
      return signedIn() && resource.data.participants[request.auth.uid] == true;
    }

    match /wallets/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /economyProgress/{uid} {
      allow read, write: if false;
    }

    match /verifiedMatchClaims/{claimId} {
      allow read, write: if false;
    }

    match /achievementProfiles/{uid} {
      allow read, write: if false;
    }

    match /valueMarketActive/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /valueMarketRooms/{roomId} {
      allow read: if isRoomMember();
      allow write: if false;
    }

    match /valueMarketQueues/{uid} {
      allow read, write: if false;
    }

    match /valueMarketStats/{uid} {
      allow read, write: if false;
    }

    match /valueMarketLedger/{entryId} {
      allow read, write: if false;
    }

    match /valueMarketAchievementPairs/{pairId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
